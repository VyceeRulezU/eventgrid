{
  "name": "eventgrid",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && tsc -b && vite build",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview-emails": "tsx --tsconfig tsconfig.app.json scripts/preview-emails.tsx",
    "analyze": "vite-bundle-visualizer",
    "sanity:dev": "echo Sanity studio has been removed",
    "sanity:build": "echo Sanity studio has been removed",
    "sanity:deploy": "echo Sanity studio has been removed"
  },
