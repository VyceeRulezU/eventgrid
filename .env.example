# EventGrid — Environment Variables
# Copy this to .env.local and fill in your values.

# ── Supabase (required) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── App ────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://your-app.vercel.app

# ── Super admin emails (comma-separated, optional) ─────────────────────────
VITE_SUPER_ADMIN_EMAILS=admin@example.com

# ── Paystack (required for event activation) ───────────────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_key_here

# ── Storage provider (supabase or r2, default: supabase) ──────────────────
VITE_STORAGE_PROVIDER=supabase

# Cloudflare R2 (optional, only if VITE_STORAGE_PROVIDER=r2)
VITE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
VITE_R2_REGION=auto
VITE_R2_ACCESS_KEY_ID=your_access_key
VITE_R2_SECRET_ACCESS_KEY=your_secret_key
VITE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
VITE_R2_BUCKET=eventgrid

# ── Supabase Edge Function secrets ─────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# (Do NOT put real values here — these go in Supabase Dashboard > Edge Functions > Secrets)

# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # auto-injected by Supabase runtime
# PAYSTACK_SECRET_KEY=sk_test_your_secret_key        # used by paystack-webhook function
# RESEND_API_KEY=re_your_resend_api_key              # used by send-invite function
# FROM_EMAIL=EventGrid <noreply@eventgrid.ng>        # verified sender in Resend
# APP_URL=https://your-app.vercel.app                # base URL for invite links
