{
  "expo": {
    "name": "NaliGrid",
    "slug": "naligrid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nalitech.naligrid",
      "infoPlist": {
        "NSCameraUsageDescription": "NaliGrid uses your camera to capture event photos and issue documentation.",
        "NSPhotoLibraryUsageDescription": "NaliGrid accesses your photos to upload event documentation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.nalitech.naligrid",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4A017",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        { "cameraPermission": "NaliGrid uses your camera to capture event photos." }
      ]
    ],
    "scheme": "naligrid",
    "experiments": {
      "typedRoutes": true
    }
  }
}
